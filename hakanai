#!/usr/bin/env bash
# hakanai -- one command to build and run the appliance.
#
#   ./hakanai          build images + bring the stack up (http://127.0.0.1:8800)
#   ./hakanai down     tear it all down (control plane, agents, proxy, networks)
#   ./hakanai smoke    creds-free checks: pinning, egress, ACP, browser-origin guard, cross-conversation isolation, memory budget
#
# The control plane (a container with the docker socket) spawns one ephemeral,
# egress-locked agent container per conversation and reaps it. The agent and
# egress images are run ad-hoc by the control plane, so we build them here; the
# control-plane image is built by compose.
set -euo pipefail
cd "$(dirname "$0")"

build() {
  docker build -q -t hakanai-agent:dev agent >/dev/null
  docker build -q -t hakanai-egress:dev egress-proxy >/dev/null
  docker build -q -t hakanai-inference:dev inference-sidecar >/dev/null
}

wait_ready() {
  # ensureInfra (networks + proxy + self-join) runs before the server listens,
  # so poll the UI until it actually answers.
  for _ in $(seq 1 40); do
    curl -sf -o /dev/null http://127.0.0.1:8800/ && return 0
    sleep 0.5
  done
  echo "control plane did not become ready" >&2
  return 1
}

# Open the UI: prefer Chrome/Chromium in --app mode (a chromeless window that
# feels like a native app), else the default browser. Opt out with HAKANAI_NO_BROWSER=1.
open_ui() {
  [ -n "${HAKANAI_NO_BROWSER:-}" ] && return 0
  local url="http://127.0.0.1:8800"
  if [ "$(uname -s)" = "Darwin" ]; then
    local app
    for app in "Google Chrome" "Chromium" "Microsoft Edge" "Brave Browser"; do
      local bin="/Applications/$app.app/Contents/MacOS/$app"
      [ -x "$bin" ] && { ( "$bin" --app="$url" >/dev/null 2>&1 & ); return 0; }
    done
    ( open "$url" >/dev/null 2>&1 & ); return 0
  fi
  local bin
  for bin in google-chrome-stable google-chrome chromium chromium-browser \
             brave-browser microsoft-edge-stable microsoft-edge; do
    if command -v "$bin" >/dev/null 2>&1; then
      ( "$bin" --app="$url" >/dev/null 2>&1 & ); return 0
    fi
  done
  for opener in xdg-open wslview; do
    command -v "$opener" >/dev/null 2>&1 && { ( "$opener" "$url" >/dev/null 2>&1 & ); return 0; }
  done
  return 1 # nothing opened; the printed URL is the fallback
}

down() {
  docker compose down 2>/dev/null || true
  docker rm -f hakanai-proxy hakanai-inference >/dev/null 2>&1 || true
  docker ps -aq --filter label=hakanai=1 | xargs -r docker rm -f >/dev/null
  docker volume ls -q --filter name=hakanai- | xargs -r docker volume rm >/dev/null
  # Per-conversation networks (hakanai-net-*) plus the shared egress net and the
  # legacy shared internal net from older builds.
  docker network ls -q --filter name=hakanai-net- | xargs -r docker network rm >/dev/null 2>&1 || true
  docker network rm hakanai-egress hakanai-internal >/dev/null 2>&1 || true
}

case "${1:-up}" in
  up)
    build
    docker compose up -d --build
    wait_ready
    echo
    echo "hakanai is up  ->  http://127.0.0.1:8800"
    echo "stop with      ->  ./hakanai down"
    open_ui || true
    ;;
  down)
    down
    echo "hakanai is down"
    ;;
  smoke)
    trap down EXIT   # always clean up, even on failure
    bash scripts/pinning-smoke.sh    # static supply-chain check (no docker)
    (cd control-plane && bun test)   # fast unit tests first (no docker)
    (cd egress-proxy && bun test)    # egress allowlist matching (no docker)
    down             # clean slate
    build
    bash scripts/egress-smoke.sh
    docker compose up -d --build
    wait_ready
    # settings-smoke runs FIRST, while the appliance is still unconfigured: it
    # asserts the 409 not_configured gate + the discover-models SSRF guard, then
    # (with creds) drives the full OpenAI provider path end to end.
    bash scripts/settings-smoke.sh
    # The remaining smokes spawn conversations, which now requires a configured
    # provider. They don't complete a model turn (only need a spawnable agent),
    # so configure a creds-free Vertex provider for them. (If settings-smoke just
    # configured OpenAI from real creds, this resets it -- fine, that path is
    # already proven above.)
    curl -sf -X POST -H "Origin: http://127.0.0.1:8800" -H "Content-Type: application/json" \
      -d '{"provider":"vertex","project":"smoke","location":"us-central1","model":"gemini-2.5-pro"}' \
      http://127.0.0.1:8800/api/settings >/dev/null
    bun scripts/acp-smoke.ts
    bash scripts/origin-smoke.sh
    bash scripts/isolation-smoke.sh
    bash scripts/export-smoke.sh
    bash scripts/limit-smoke.sh
    bash scripts/clock-smoke.sh
    echo "smokes passed"
    ;;
  help | -h | --help)
    cat <<'EOF'
hakanai -- a provably-deletable AI chat appliance

  ./hakanai [up]    build images, start the stack, open the UI (http://127.0.0.1:8800)
  ./hakanai down    stop and remove everything (containers, proxy, networks, volumes)
  ./hakanai smoke   creds-free checks (egress containment + ACP handshake + cross-conversation isolation)
  ./hakanai help    this message

Model -- configured at RUNTIME in the Settings UI (the gear in the sidebar), not
via env. Two provider modes:

  OpenAI-compatible   an endpoint URL + a (narrow, scoped) token + a model. The
                      token lives in the agent, contained by the egress
                      allowlist to that one endpoint host; the agent reaches it
                      directly through the proxy.
  Google Vertex       project + location + model, plus "Connect Google" (an
                      out-of-band gcloud ADC login). The broad credential stays
                      OUT of the agent, in the inference sidecar; the agent has
                      no internet and talks only to the sidecar.

The config is global (one active backend) and persists on the state volume
(settings.json, 0600; Vertex ADC as adc.json). Other:

  HAKANAI_NO_BROWSER=1     do not auto-open the UI
  EGRESS_ALLOW=a,b         extra hosts the sidecar may reach (rarely needed)
EOF
    ;;
  *)
    echo "unknown command: $1" >&2
    echo "try: ./hakanai help" >&2
    exit 1
    ;;
esac
